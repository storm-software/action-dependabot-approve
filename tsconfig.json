{
  "compilerOptions": {
    "target": "ES5",
    "module": "commonjs",
    "lib": ["ES2015", "DOM"],
    "outDir": "dist",
    "types": ["node"],
    "noEmit": true,
    "isolatedModules": true,
    "strict": true,
    "esModuleInterop": true
  },
  "include": ["index.ts"],
  "exclude": ["node_modules", "**/*.spec.ts"]
}
